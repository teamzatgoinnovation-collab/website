# ZatGo marketing (Next.js) — copy to `.env.local`
# Never commit real secrets.

# ─── Site ───────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://www.zatgo.com
# NEXT_PUBLIC_OG_IMAGE_URL=https://www.zatgo.com/custom-og.png
# NEXT_PUBLIC_COMPANY_EMAIL=hello@zatgo.com
# NEXT_PUBLIC_PHONE=
# NEXT_PUBLIC_WHATSAPP=
# NEXT_PUBLIC_COMPANY_ADDRESS=
# NEXT_PUBLIC_SUPPORT_URL=
# NEXT_PUBLIC_DOWNLOADS_URL=/downloads
# NEXT_PUBLIC_LINKEDIN=
# NEXT_PUBLIC_X=
# NEXT_PUBLIC_YOUTUBE=
# NEXT_PUBLIC_FACEBOOK=

# ─── Downloads (production) ─────────────────────────────────────────────────
# Prefer one CDN/base URL. Never set localhost values in production.
# DOWNLOAD_BASE_URL=https://downloads.zatgo.com
# NEXT_PUBLIC_DOWNLOAD_BASE_URL=https://downloads.zatgo.com
#
# Resolves automatically to:
#   {base}/apps/project-tracker
#   {base}/apps/customer-portal
#   {base}/apps/vendor-portal
#   {base}/apps/admin-console
#   {base}/apps/bi-dashboard
#   {base}/apps/crm
#   {base}/docs
#   {base}/releases/{fileName}
#
# Optional per-product overrides (win over DOWNLOAD_BASE_URL):
# NEXT_PUBLIC_PROJECT_TRACKER_WEB_URL=https://tracker.zatgo.com
# NEXT_PUBLIC_CUSTOMER_PORTAL_URL=https://customers.zatgo.com
# NEXT_PUBLIC_VENDOR_PORTAL_URL=https://vendors.zatgo.com
# NEXT_PUBLIC_ADMIN_PORTAL_URL=https://admin.zatgo.com
# NEXT_PUBLIC_BI_DASHBOARD_URL=https://bi.zatgo.com
# NEXT_PUBLIC_CRM_PORTAL_URL=https://crm.zatgo.com
# NEXT_PUBLIC_DOCS_URL=https://docs.zatgo.com
#
# Optional installer / docker gates:
# NEXT_PUBLIC_RELEASES_BASE_URL=https://downloads.zatgo.com/releases
# NEXT_PUBLIC_DOCKER_PLATFORM_URL=https://docs.zatgo.com/deploy/docker
# NEXT_PUBLIC_DOCKER_PLATFORM_IMAGE=ghcr.io/zatgo/platform:latest

# ─── Lead API (POST /api/leads) ──────────────────────────────────────────────
# LEADS_WEBHOOK_URL=https://hooks.example.com/leads
# LEADS_NOTIFY_EMAIL=leads@zatgo.com
# LEADS_STORE_DIR=/var/data/zatgo-leads
# LEADS_RETRY_SECRET=change-me
#
# Redis rate limiting (prefer Upstash on Vercel; REDIS_URL for classic Redis):
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
# REDIS_URL=redis://default:password@host:6379
#
# If Redis is unavailable, the API falls back to in-memory limiting.
